# Interactive shell config, split into topic files under rc.d/.
# Files are sourced in numeric-prefix order — the order is LOAD-BEARING:
#   20-homebrew  (BREW_PREFIX)  ->  30-appearance (LS_COLORS)  ->
#   40-completion (compinit, fzf-tab)  ->  50-tools (starship/fzf/zoxide,
#   autosuggestions, syntax-highlighting, history-substring-search LAST)  ->
#   55-atuin (Ctrl-R)  ->  60-keybindings (Up/Down).
# To add config: drop a new NN-topic.zsh in rc.d/ (pick NN to place it correctly).
for _rc in "${ZDOTDIR:-$HOME/.config/zsh}"/rc.d/*.zsh(N); do
  source "$_rc"
done
unset _rc
